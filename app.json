{
  "expo": {
    "name": "ShopApp",
    "owner": "adi_10",
    "slug": "ShopApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": [
      "shopapp",
      "com.googleusercontent.apps.865209207153-tc98eobq0ujacjoi98n0m5qom7o5ipfe"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopapp.mobile"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.shopapp.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ShopApp to access your camera for taking product and profile photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ShopApp to access your photos for uploading images."
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      "./plugins/withFirebaseMessaging"
    ],
    "extra": {
      "eas": {
        "projectId": "3998001b-225e-4805-9b55-f92bb933193c"
      },
      "EXPO_PUBLIC_FIREBASE_API_KEY": "AIzaSyA-l185FMGgCrhnz2CtQmFusIZxPyVCyjs",
      "EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN": "expo-97519.firebaseapp.com",
      "EXPO_PUBLIC_FIREBASE_PROJECT_ID": "expo-97519",
      "EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET": "expo-97519.firebasestorage.app",
      "EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "865209207153",
      "EXPO_PUBLIC_FIREBASE_APP_ID": "1:865209207153:web:8cda09eaa3328f9cd14ed0",
      "EXPO_PUBLIC_API_URL": "https://shopapp-backend-27yn.onrender.com/api",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "865209207153-95s5ijpg59a2ltkksbld2eh30etpoe09.apps.googleusercontent.com",
      "EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID": "865209207153-tc98eobq0ujacjoi98n0m5qom7o5ipfe.apps.googleusercontent.com",
